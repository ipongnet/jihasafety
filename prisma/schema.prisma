generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model CityContact {
  id          Int          @id @default(autoincrement())
  sido        String
  sigungu     String
  personName  String
  email       String
  phone       String
  department  String?
  submissions Submission[]

  @@unique([sido, sigungu])
}

model Department {
  id       Int          @id @default(autoincrement())
  name     String       @unique
  parentId Int?
  parent   Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children Department[] @relation("DeptTree")
}

model Submission {
  id                    Int          @id @default(autoincrement())
  projectName           String
  companyName           String
  constructionStartDate DateTime
  constructionEndDate   DateTime
  fullAddress           String
  sido                  String
  sigungu               String
  latitude              Float?
  longitude             Float?
  submitterEmail        String?
  emailSentTo           String?
  status                String
  consentGiven          Boolean      @default(true)
  submissionNumber      String?      @unique
  cityContactId         Int?
  cityContact           CityContact? @relation(fields: [cityContactId], references: [id])
  createdAt             DateTime     @default(now())

  @@index([status, createdAt])
  @@index([sido, sigungu])
}
